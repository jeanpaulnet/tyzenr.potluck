{
  "entities": {
    "Guest": {
      "title": "Guest",
      "description": "A guest attending the potluck",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Dish": {
      "title": "Dish",
      "description": "A dish brought to the potluck",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "count": { "type": "number" },
        "ownerIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "name", "count"]
    },
    "Potluck": {
      "title": "Potluck",
      "description": "A potluck event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "totalPeople": { "type": "number" },
        "notes": { "type": "string" },
        "comments": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "guests": {
          "type": "array",
          "items": { "$ref": "Guest" }
        },
        "dishes": {
          "type": "array",
          "items": { "$ref": "Dish" }
        },
        "otherItems": {
          "type": "array",
          "items": { "$ref": "Dish" }
        }
      },
      "required": ["id", "title", "ownerId", "createdAt"]
    }
  },
  "firestore": {
    "/potlucks/{potluckId}": {
      "schema": "Potluck",
      "description": "Collection of potluck events"
    }
  }
}
